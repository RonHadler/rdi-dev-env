{
  "name": "python-fastmcp",
  "description": "FastMCP server overlay: coordinator pattern, MCP tools, health endpoint",
  "layer": 2,
  "extends": "python",
  "detect": { "file_contains": { "path": "pyproject.toml", "pattern": "fastmcp" } },
  "markers": ["Project Name", "project-name", "package_name", "PACKAGE_NAME", "description", "date", "GCP project ID", "GCP region"],
  "files": {
    "managed": [],
    "seeded": [
      "pyproject.toml",
      "Dockerfile",
      "Makefile",
      ".env.example"
    ]
  },
  "fragments": {
    "CLAUDE.md": [
      "claude-commands",
      "claude-session-startup",
      "claude-resources"
    ],
    "AGENTS.md": [
      "agents-tech-stack",
      "agents-architecture",
      "agents-file-structure",
      "agents-env-vars",
      "agents-commands"
    ],
    "GEMINI.md": [
      "gemini-quality-standards",
      "gemini-architectural-constraints",
      "gemini-common-violations",
      "gemini-testing-standards"
    ]
  },
  "scaffold": {
    "directories": ["models", "tools"],
    "files": {
      "coordinator.py": "scaffold/coordinator.py",
      "config.py": "scaffold/config.py",
      "server.py": "scaffold/server.py",
      "__main__.py": "scaffold/__main__.py",
      "tests/conftest.py": "scaffold/tests/conftest.py",
      "tests/test_coordinator.py": "scaffold/tests/test_coordinator.py"
    }
  }
}
